page {
  background-color: #FAFAFA;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.title {
  font-size: 48rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 20rpx;
}

.slogan {
  font-size: 28rpx;
  color: #888888;
  margin-bottom: 80rpx;
}

.input-area {
  width: 100%;
  margin-bottom: 40rpx;
}

.input {
  width: 100%;
  padding: 30rpx;
  background: #FFFFFF;
  border: 2rpx solid #EEEEEE;
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #111111;
}

.btn-primary {
  width: 100%;
  padding: 30rpx;
  background: #111111;
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 20rpx;
}

.btn-secondary {
  width: 100%;
  padding: 30rpx;
  background: #FFFFFF;
  color: #111111;
  border: 2rpx solid #EEEEEE;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}
