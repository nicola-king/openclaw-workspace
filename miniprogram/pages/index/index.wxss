page {
  background-color: #FAFAFA;
}

.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.input {
  width: 100%;
  padding: 30rpx;
  background: #FFFFFF;
  border: 2rpx solid #EEEEEE;
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #111111;
  margin-bottom: 40rpx;
}

.placeholder {
  color: #CCCCCC;
}

.btn-primary {
  width: 100%;
  padding: 30rpx;
  background: #111111;
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 20rpx;
}

.btn-secondary {
  width: 100%;
  padding: 30rpx;
  background: #FFFFFF;
  color: #111111;
  border: 2rpx solid #EEEEEE;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}
