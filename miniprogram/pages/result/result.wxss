page {
  background-color: #FAFAFA;
}

.container {
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.card-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.stage-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.stage-name {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #111111;
}

.step-indicator {
  text-align: center;
  margin-bottom: 40rpx;
}

.step-indicator text {
  font-size: 26rpx;
  color: #888888;
}

.divider {
  width: 100%;
  height: 2rpx;
  background: #EEEEEE;
  margin: 40rpx 0;
}

.core-state {
  text-align: center;
  margin-bottom: 40rpx;
}

.core-state text {
  font-size: 34rpx;
  color: #111111;
  line-height: 1.8;
}

.tag {
  text-align: center;
  margin-bottom: 30rpx;
}

.tag text {
  font-size: 28rpx;
  color: #666666;
}

.hashtags {
  text-align: center;
  margin-bottom: 60rpx;
}

.hashtags text {
  font-size: 24rpx;
  color: #AAAAAA;
}

.unlock-btn {
  width: 100%;
  padding: 30rpx;
  background: #111111;
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 20rpx;
}

.retry-btn {
  width: 100%;
  padding: 30rpx;
  background: transparent;
  color: #888888;
  border: 2rpx solid #DDDDDD;
  border-radius: 16rpx;
  font-size: 32rpx;
  text-align: center;
}
