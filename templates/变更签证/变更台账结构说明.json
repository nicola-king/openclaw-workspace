{
  "filename": "变更台账自动化工具 - 渝中区污水溢流项目.xlsx",
  "sheets": [
    {
      "name": "1️⃣台账总表",
      "description": "所有变更签证的汇总视图，含自动预警和证据评分",
      "columns": [
        {
          "col": "A",
          "name": "序号",
          "formula": "=ROW()-1"
        },
        {
          "col": "B",
          "name": "变更编号",
          "example": "BG-2026-001"
        },
        {
          "col": "C",
          "name": "变更名称",
          "example": "经纬大道管径变更"
        },
        {
          "col": "D",
          "name": "变更类型",
          "dropdown": [
            "A 类重大",
            "B 类较大",
            "C 类一般",
            "D 类微小"
          ]
        },
        {
          "col": "E",
          "name": "申报日期",
          "format": "yyyy-mm-dd"
        },
        {
          "col": "F",
          "name": "位置/桩号"
        },
        {
          "col": "G",
          "name": "变更原因",
          "dropdown": [
            "管线冲突",
            "地质变化",
            "居民协调",
            "设计优化",
            "其他"
          ]
        },
        {
          "col": "H",
          "name": "申报金额",
          "format": "¥#,##0.00"
        },
        {
          "col": "I",
          "name": "审批金额",
          "format": "¥#,##0.00"
        },
        {
          "col": "J",
          "name": "核减金额",
          "formula": "=H2-I2"
        },
        {
          "col": "K",
          "name": "核减率",
          "formula": "=IF(H2=0,0,J2/H2)",
          "format": "0.00%"
        },
        {
          "col": "L",
          "name": "审批状态",
          "dropdown": [
            "已批",
            "审批中",
            "被拒",
            "已撤销"
          ]
        },
        {
          "col": "M",
          "name": "审批日期",
          "format": "yyyy-mm-dd"
        },
        {
          "col": "N",
          "name": "审批天数",
          "formula": "=IF(AND(M2<>\"\",E2<>\"\"),M2-E2,\"\")"
        },
        {
          "col": "O",
          "name": "超时天数",
          "formula": "=IF(L2=\"已批\",IF(N2>VLOOKUP(D2,系统设置!$A$2:$B$5,2,FALSE),N2-VLOOKUP(D2,系统设置!$A$2:$B$5,2,FALSE),0),TODAY()-E2-VLOOKUP(D2,系统设置!$A$2:$B$5,2,FALSE))"
        },
        {
          "col": "P",
          "name": "预警级别",
          "formula": "=IF(O2<=3,\"🟢正常\",IF(O2<=7,\"🟡关注\",IF(O2<=14,\"🟠预警\",\"🔴警报\")))"
        },
        {
          "col": "Q",
          "name": "证据完整性",
          "format": "0"
        },
        {
          "col": "R",
          "name": "证据等级",
          "formula": "=IF(Q2>=90,\"🟢完整\",IF(Q2>=70,\"🟡基本完整\",IF(Q2>=50,\"🟠高风险\",\"🔴缺失\")))"
        },
        {
          "col": "S",
          "name": "是否纳入进度款",
          "dropdown": [
            "是",
            "否"
          ]
        },
        {
          "col": "T",
          "name": "进度款期数"
        },
        {
          "col": "U",
          "name": "责任人"
        },
        {
          "col": "V",
          "name": "备注"
        }
      ]
    },
    {
      "name": "7️⃣系统设置",
      "data": [
        [
          "参数名称",
          "参数值"
        ],
        [
          "A 类变更审批时限",
          15
        ],
        [
          "B 类变更审批时限",
          10
        ],
        [
          "C 类变更审批时限",
          7
        ],
        [
          "D 类变更审批时限",
          3
        ],
        [
          "证据完整性阈值 (优秀)",
          90
        ],
        [
          "证据完整性阈值 (良好)",
          70
        ],
        [
          "证据完整性阈值 (合格)",
          50
        ]
      ]
    }
  ]
}