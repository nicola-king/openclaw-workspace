{
  "dashboard": {
    "title": "太一 Gateway 总览",
    "tags": ["taiyi", "gateway"],
    "timezone": "Asia/Shanghai",
    "panels": [
      {
        "id": 1,
        "title": "Gateway 状态",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"gateway\"}",
            "legendFormat": "Gateway"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "options": {"0": {"text": "❌ Down", "color": "red"}}},
              {"type": "value", "options": {"1": {"text": "✅ Up", "color": "green"}}}
            ]
          }
        }
      },
      {
        "id": 2,
        "title": "内存使用",
        "type": "gauge",
        "targets": [
          {
            "expr": "process_resident_memory_bytes{job=\"gateway\"} / 1024 / 1024",
            "legendFormat": "Memory (MB)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 1024, "color": "yellow"},
                {"value": 2048, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "CPU 使用率",
        "type": "gauge",
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total{job=\"gateway\"}[5m]) * 100",
            "legendFormat": "CPU %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 100,
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 50, "color": "yellow"},
                {"value": 80, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "请求延迟 (P95)",
        "type": "stat",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"gateway\"}[5m]))",
            "legendFormat": "P95 Latency"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 0.2, "color": "yellow"},
                {"value": 0.5, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "请求量 (5 分钟)",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{job=\"gateway\"}[5m]) * 300",
            "legendFormat": "Requests"
          }
        ]
      },
      {
        "id": 6,
        "title": "错误率",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{job=\"gateway\",status=~\"5..\"}[5m]) / rate(http_requests_total{job=\"gateway\"}[5m]) * 100",
            "legendFormat": "Error Rate %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent"
          }
        }
      }
    ],
    "refresh": "10s",
    "time": {
      "from": "now-1h",
      "to": "now"
    }
  }
}
