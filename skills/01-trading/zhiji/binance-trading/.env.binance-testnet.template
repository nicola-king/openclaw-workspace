# 币安测试网配置模板

# 复制此文件为 .env.binance-testnet 并填入你的 API Key
# 命令：cp .env.binance-testnet.template .env.binance-testnet

# 币安测试网 API
BINANCE_TESTNET=true
BINANCE_API_KEY=你的测试网 API Key
BINANCE_SECRET_KEY=你的测试网 Secret Key
BINANCE_BASE_URL=https://testnet.binance.vision

# 测试资金
TESTNET_INITIAL_BALANCE=10000

# 交易配置
KELLY_MODE=quarter
CONFIDENCE_THRESHOLD=0.96
MAX_POSITION_USDT=500

# 交易对 (仅 BTC/ETH)
TRADING_PAIRS=BTCUSDT,ETHUSDT
BTC_ALLOCATION=0.60
ETH_ALLOCATION=0.40

# 铁律
ALLOW_ALTCOINS=false           # 不交易山寨币
ALLOW_SPOT_LEVERAGE=true       # 允许现货杠杆
ALLOW_FUTURES=false            # 不开合约
MAX_LEVERAGE=3                 # 最大 3 倍杠杆

# 风控配置
DAILY_STOP_LOSS=-0.05
SINGLE_TRADE_STOP=-0.02
PROFIT_WITHDRAW=0.50
