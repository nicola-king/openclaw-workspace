/* pages/test/test.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
}

.progress-bar {
  height: 8rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 4rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.progress {
  height: 100%;
  background: white;
  transition: width 0.3s;
}

.progress-text {
  text-align: center;
  color: white;
  font-size: 24rpx;
  margin-bottom: 40rpx;
  opacity: 0.9;
}

.question-card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
}

.question-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.option {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.option:active {
  transform: scale(0.98);
}

.option.selected {
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.05);
}

.option-label {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.option.selected .option-label {
  background: #667eea;
  color: white;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.actions {
  text-align: center;
}

.submit-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 48rpx;
  padding: 28rpx 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  width: 100%;
}

.submit-btn[disabled] {
  opacity: 0.5;
}

/* 结果卡片 */
.result-card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
}

.result-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.state-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.state-type {
  display: inline-block;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.result-body {
  margin-bottom: 40rpx;
}

.stage-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stage-label {
  font-size: 28rpx;
  color: #999;
}

.stage-text {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.confidence {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.confidence-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.primary-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 48rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.secondary-btn {
  background: white;
  color: #667eea;
  border: 2rpx solid #667eea;
  border-radius: 48rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: bold;
}
