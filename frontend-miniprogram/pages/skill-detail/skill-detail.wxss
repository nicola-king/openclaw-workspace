/* pages/skill-detail/skill-detail.wxss */
.container {
  min-height: 100vh;
  background: #f8f9fa;
  padding: 40rpx;
  padding-bottom: 200rpx;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
  color: white;
  margin-bottom: 30rpx;
}

.state-name {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.stage-info {
  font-size: 26rpx;
  opacity: 0.9;
}

.section-icon {
  font-size: 64rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

/* 核心决策 */
.decision-section {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.decision-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #667eea;
  line-height: 1.6;
}

/* 具体行动 */
.action-section {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.action-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.action-number {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.action-content {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  padding-top: 8rpx;
}

/* 避免事项 */
.avoid-section {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.avoid-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.avoid-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.avoid-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #fee;
  color: #f44;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.avoid-content {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  padding-top: 8rpx;
}

/* 心理学解读 */
.psychology-section {
  margin-bottom: 30rpx;
}

.psychology-card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.psychology-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.psychology-icon {
  font-size: 32rpx;
}

.psychology-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.psychology-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  padding-left: 44rpx;
}

/* 底部操作 */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 30rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.05);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.share-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 48rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.home-btn {
  background: white;
  color: #667eea;
  border: 2rpx solid #667eea;
  border-radius: 48rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: bold;
}
